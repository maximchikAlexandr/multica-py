# Live integration test environment template (non-secret values only).
# Copy to a local .env file or export manually before running live tests.

MULTICA_LIVE_TARGET_FILE=contracts/multica-live-target.toml
MULTICA_LIVE_UPSTREAM_DIR=/absolute/path/to/multica
MULTICA_LIVE_CLI=/absolute/path/to/multica/server/bin/multica
# MULTICA_LIVE_RESOLVE_CLI=1
# MULTICA_LIVE_ARTIFACT_DIR=/absolute/path/to/multica-py/.live-artifacts
# MULTICA_LIVE_MODE=smoke
# MULTICA_LIVE_EXISTING_URL=http://127.0.0.1:8080
# MULTICA_LIVE_READY_TIMEOUT=120
# MULTICA_LIVE_KEEP_ENV=1
